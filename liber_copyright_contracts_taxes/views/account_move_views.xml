<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Smart buttons linking author bills and the IRRF tax bill -->
    <record id="view_move_form_edlab_taxes" model="ir.ui.view">
        <field name="name">account.move.form.edlab.taxes</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <field name="edlab_is_tax_bill" invisible="1"/>
                <field name="edlab_tax_move_id" invisible="1"/>
                <button name="action_open_tax_bill" type="object"
                        class="oe_stat_button" icon="fa-university"
                        groups="liber_copyright_contracts.group_contract_manager"
                        invisible="not edlab_tax_move_id">
                    <div class="o_stat_info">
                        <span class="o_stat_text">IRRF</span>
                        <span class="o_stat_text">Tax Bill</span>
                    </div>
                </button>
                <button name="action_open_tax_origin_bills" type="object"
                        class="oe_stat_button" icon="fa-users"
                        groups="liber_copyright_contracts.group_contract_manager"
                        invisible="edlab_tax_origin_count == 0">
                    <field name="edlab_tax_origin_count" widget="statinfo"
                           string="Author Bills"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
