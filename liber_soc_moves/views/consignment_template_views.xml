<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_consignment_template_list" model="ir.ui.view">
        <field name="name">consignment.template.list</field>
        <field name="model">consignment.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="product_count"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_consignment_template_form" model="ir.ui.view">
        <field name="name">consignment.template.form</field>
        <field name="model">consignment.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Lançamento Infantil"/></h1>
                    </div>
                    <group>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                    <notebook>
                        <page string="Products" name="products">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="product_uom_qty"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_consignment_template" model="ir.actions.act_window">
        <field name="name">Campaigns</field>
        <field name="res_model">consignment.template</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a consignment order template
            </p>
            <p>
                A reusable pre-set list of products you can load into a
                consignment with one click.
            </p>
        </field>
    </record>

</odoo>
