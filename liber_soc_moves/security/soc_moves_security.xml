<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Multi-company: consignment movements and templates are only visible for
         the companies selected in the company switcher (records with no company
         stay visible to all). -->
    <record id="consignment_move_company_rule" model="ir.rule">
        <field name="name">Consignment Move: multi-company</field>
        <field name="model_id" ref="model_consignment_move"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_id', 'in', company_ids), ('company_id', '=', False)]</field>
    </record>

    <record id="consignment_template_company_rule" model="ir.rule">
        <field name="name">Consignment Template: multi-company</field>
        <field name="model_id" ref="model_consignment_template"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_id', 'in', company_ids), ('company_id', '=', False)]</field>
    </record>
</odoo>
