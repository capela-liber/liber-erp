<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_form_soc" model="ir.ui.view">
        <field name="name">res.partner.form.soc</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button type="object" name="action_view_consignment_agreements"
                        class="oe_stat_button" icon="fa-handshake-o"
                        invisible="consignment_agreement_count == 0">
                    <field name="consignment_agreement_count" widget="statinfo"
                           string="Consignment"/>
                </button>
            </div>
        </field>
    </record>

</odoo>
