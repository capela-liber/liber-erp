<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- "A convencao de duas letras e para os disparadores. Acho que temos aqui
         mais uma situacao de disparo. 'BO'?" (dele, decisao D4). O disparo
         segue CR/ CO/ CP/ da casa; a ficha individual nao e disparador, entao
         nao leva duas letras: B00231. -->
    <record id="seq_product_bonus_dispatch" model="ir.sequence">
        <field name="name">Bonus Dispatch</field>
        <field name="code">product.bonus.dispatch</field>
        <field name="prefix">BO/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_product_bonus" model="ir.sequence">
        <field name="name">Bonus Copy</field>
        <field name="code">product.bonus</field>
        <field name="prefix">B</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
