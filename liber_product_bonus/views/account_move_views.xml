<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_bonus" model="ir.ui.view">
        <field name="name">account.move.form.bonus</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Vínculo de volta: do lançamento para a bonificação que o gerou. -->
            <div name="button_box" position="inside">
                <button name="action_open_bonus" type="object"
                        class="oe_stat_button" icon="fa-gift"
                        invisible="not bonus_id">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Bonificação</span>
                    </div>
                </button>
            </div>
        </field>
    </record>
    <!-- O filtro da nossa origem no menu Remessas do financeiro. -->
    <record id="view_nfe_remessa_search_bonus" model="ir.ui.view">
        <field name="name">account.move.search.remessa.bonus</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="liber_nfe_remessa.view_nfe_remessa_search"/>
        <field name="arch" type="xml">
            <field name="invoice_origin" position="after">
                <filter name="filter_bonus" string="Bonificações"
                        domain="[('remessa_origin', '=', 'bonus')]"/>
            </field>
        </field>
    </record>
</odoo>
