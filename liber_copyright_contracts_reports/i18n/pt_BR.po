#. module: liber_copyright_contracts_reports
#: model:mail.template,body_html:liber_copyright_contracts_reports.mail_template_royalty_statement
msgid ""
"<div style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"    <p>Olá, <t t-out=\"object.name\"/>,</p>\n"
"    <p>\n"
"        Segue em anexo a prestação de contas dos seus direitos autorais\n"
"        referente ao período <t t-out=\"ctx.get('edlab_period_label', '')\"/>.\n"
"    </p>\n"
"    <p>\n"
"        Valor a receber no período: <strong t-out=\"ctx.get('edlab_net_label', '')\"/>.\n"
"    </p>\n"
"    <p>\n"
"        Em caso de dúvida sobre os valores ou os dados cadastrais, basta\n"
"        responder este e-mail.\n"
"    </p>\n"
"    <p>Atenciosamente,<br/><t t-out=\"user.company_id.name\"/></p>\n"
"</div>\n"
"            "
