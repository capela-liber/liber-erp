<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_liber_github" model="ir.module.category">
        <field name="name">GitHub Files</field>
        <field name="sequence">25</field>
    </record>

    <record id="privilege_liber_github" model="res.groups.privilege">
        <field name="name">GitHub Files</field>
        <field name="category_id" ref="module_category_liber_github"/>
    </record>

    <record id="group_liber_github_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="privilege_liber_github"/>
        <field name="implied_ids"
               eval="[(4, ref('liber_cloud_files.group_liber_cloud_user'))]"/>
    </record>

    <record id="group_liber_github_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_liber_github"/>
        <field name="implied_ids"
               eval="[(4, ref('group_liber_github_user')),
                      (4, ref('liber_cloud_files.group_liber_cloud_manager'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <record id="rule_liber_github_folder_manager" model="ir.rule">
        <field name="name">GitHub managers see every GitHub folder</field>
        <field name="model_id"
               ref="liber_cloud_files.model_liber_cloud_folder"/>
        <field name="domain_force">[('provider', '=', 'github')]</field>
        <field name="groups" eval="[(4, ref('group_liber_github_manager'))]"/>
    </record>

    <record id="rule_liber_github_file_manager" model="ir.rule">
        <field name="name">GitHub managers see every GitHub file</field>
        <field name="model_id"
               ref="liber_cloud_files.model_liber_cloud_file"/>
        <field name="domain_force">[('provider', '=', 'github')]</field>
        <field name="groups" eval="[(4, ref('group_liber_github_manager'))]"/>
    </record>

</odoo>
