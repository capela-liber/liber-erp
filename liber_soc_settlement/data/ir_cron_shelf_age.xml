<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
          The shelf age is stored so the On Shelf report can sort and filter by
          it (a non-stored field has no column to sort by). But it grows on its
          own: no write anywhere makes "days since the last acerto" go up, so no
          @api.depends can catch it. It is refreshed on a clock instead.
        -->
        <record id="cron_refresh_shelf_age" model="ir.cron">
            <field name="name">Consignment: refresh shelf age</field>
            <field name="model_id" ref="stock.model_stock_quant"/>
            <field name="state">code</field>
            <field name="code">model._cron_refresh_shelf_age()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
            <field name="nextcall"
                   eval="(DateTime.now().replace(hour=5, minute=30, second=0) + timedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
        </record>
    </data>
</odoo>
