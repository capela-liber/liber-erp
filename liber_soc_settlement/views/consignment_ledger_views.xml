<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_consignment_ledger_list" model="ir.ui.view">
        <field name="name">consignment.ledger.list</field>
        <field name="model">consignment.ledger</field>
        <field name="arch" type="xml">
            <list string="Shelf Ledger" create="false" edit="false" delete="false"
                  default_order="date desc">
                <field name="date"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="source" widget="badge"
                       decoration-info="source == 'stock'"
                       decoration-muted="source == 'fiscal'"/>
                <field name="kind" widget="badge"
                       decoration-success="kind == 'ship'"
                       decoration-danger="kind == 'sale'"
                       decoration-warning="kind == 'return'"/>
                <field name="qty_in" sum="In"/>
                <field name="qty_out" sum="Out"/>
                <field name="quantity" sum="Balance" decoration-bf="1"/>
                <field name="document" optional="show"/>
                <field name="company_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_consignment_ledger_pivot" model="ir.ui.view">
        <field name="name">consignment.ledger.pivot</field>
        <field name="model">consignment.ledger</field>
        <field name="arch" type="xml">
            <!-- Source across the columns on purpose: side by side, the gap
                 between what sold on paper and what left the shelf in Odoo is
                 the whole point of this report. -->
            <pivot string="Shelf Ledger" sample="1">
                <field name="partner_id" type="row"/>
                <field name="product_id" type="row"/>
                <field name="source" type="col"/>
                <field name="quantity" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_consignment_ledger_graph" model="ir.ui.view">
        <field name="name">consignment.ledger.graph</field>
        <field name="model">consignment.ledger</field>
        <field name="arch" type="xml">
            <graph string="Shelf Ledger" type="line" sample="1">
                <field name="date" interval="month"/>
                <field name="kind"/>
                <field name="quantity" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_consignment_ledger_search" model="ir.ui.view">
        <field name="name">consignment.ledger.search</field>
        <field name="model">consignment.ledger</field>
        <field name="arch" type="xml">
            <search string="Shelf Ledger">
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="document"/>
                <filter name="f_ship" string="Shipments" domain="[('kind', '=', 'ship')]"/>
                <filter name="f_sale" string="Sales" domain="[('kind', '=', 'sale')]"/>
                <filter name="f_return" string="Returns" domain="[('kind', '=', 'return')]"/>
                <separator/>
                <filter name="f_stock" string="Odoo stock" domain="[('source', '=', 'stock')]"/>
                <filter name="f_fiscal" string="Fiscal (NFe)" domain="[('source', '=', 'fiscal')]"/>
                <separator/>
                <filter name="f_date" string="Date" date="date"/>
                <group>
                    <filter name="g_partner" string="Customer" domain="[]" context="{'group_by': 'partner_id'}"/>
                    <filter name="g_product" string="Title" domain="[]" context="{'group_by': 'product_id'}"/>
                    <filter name="g_source" string="Source" domain="[]" context="{'group_by': 'source'}"/>
                    <filter name="g_kind" string="Movement" domain="[]" context="{'group_by': 'kind'}"/>
                    <!-- Group by the FIELD, not by a granularity: Odoo renders a
                         date group-by with its own Year/Quarter/Month/Week/Day
                         submenu. Pinning it to 'date:month' and labelling it
                         "Month" just hid the field's name behind one of its
                         options. -->
                    <filter name="g_date" string="Date" domain="[]" context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_consignment_ledger" model="ir.actions.act_window">
        <field name="name">Shelf Ledger</field>
        <field name="res_model">consignment.ledger</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="search_view_id" ref="view_consignment_ledger_search"/>
        <field name="context">{'search_default_g_partner': 1, 'search_default_g_product': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No movement on any shelf yet.</p>
            <p>Every unit in and out of a customer's shelf, from Odoo's stock and
               from the imported NFe. Group by Source to see where the two
               disagree.</p>
        </field>
    </record>

</odoo>
