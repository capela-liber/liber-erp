<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_consignment_agreement_form_settlements" model="ir.ui.view">
        <field name="name">consignment.agreement.form.settlements</field>
        <field name="model">consignment.agreement</field>
        <field name="inherit_id" ref="liber_soc_agreements.view_consignment_agreement_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_view_settlements" type="object"
                        class="oe_stat_button" icon="fa-usd"
                        invisible="settlement_count == 0">
                    <field name="settlement_count" widget="statinfo" string="Consignments"/>
                </button>
            </div>
        </field>
    </record>

</odoo>
