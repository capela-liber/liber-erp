<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
      Ruptura: the campaign target that was not met, and WHY.

      "Faltou: 1.489" told nobody anything. Neither does it now, unless the miss
      carries its cause: no stock (estoque), a person who sent less (manual), a
      campaign that was never applied (falta), or one nobody has run in weeks
      (tempo). Same measure, now with axes: customer, title, channel, campaign,
      month, and above all the NATURE, because the four demand four different
      answers (reprint / retrain / apply the campaign / go settle the customer).
    -->

    <record id="view_shortfall_list" model="ir.ui.view">
        <field name="name">consignment.shortfall.list</field>
        <field name="model">consignment.shortfall</field>
        <field name="arch" type="xml">
            <list string="Ruptura" create="false" edit="false" delete="false"
                  default_order="qty_short desc">
                <field name="date"/>
                <field name="nature" widget="badge"
                       decoration-danger="nature == 'estoque'"
                       decoration-warning="nature == 'manual'"
                       decoration-info="nature == 'falta'"
                       decoration-muted="nature == 'tempo'"/>
                <field name="partner_id"/>
                <field name="product_id" width="320px"/>
                <field name="campaign_id" optional="show"/>
                <field name="settlement_id" optional="show"/>
                <field name="team_id" optional="hide"/>
                <field name="qty_on_shelf" string="Map" optional="hide"/>
                <field name="qty_target" sum="Target" optional="show"/>
                <field name="qty_on_hand" string="On Hand" optional="hide"/>
                <field name="qty_incoming" string="Inbound" optional="hide"/>
                <field name="qty_short" sum="Short" decoration-bf="1"
                       decoration-danger="qty_short &gt; 0"/>
            </list>
        </field>
    </record>

    <record id="view_shortfall_pivot" model="ir.ui.view">
        <field name="name">consignment.shortfall.pivot</field>
        <field name="model">consignment.shortfall</field>
        <field name="arch" type="xml">
            <pivot string="Ruptura" sample="1">
                <field name="nature" type="col"/>
                <field name="product_id" type="row"/>
                <field name="qty_short" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_shortfall_graph" model="ir.ui.view">
        <field name="name">consignment.shortfall.graph</field>
        <field name="model">consignment.shortfall</field>
        <field name="arch" type="xml">
            <graph string="Ruptura" type="bar" sample="1">
                <field name="nature"/>
                <field name="qty_short" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_shortfall_search" model="ir.ui.view">
        <field name="name">consignment.shortfall.search</field>
        <field name="model">consignment.shortfall</field>
        <field name="arch" type="xml">
            <search string="Ruptura">
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="campaign_id"/>
                <field name="settlement_id"/>
                <filter name="f_estoque" string="Estoque"
                        domain="[('nature', '=', 'estoque')]"/>
                <filter name="f_manual" string="Manual"
                        domain="[('nature', '=', 'manual')]"/>
                <filter name="f_falta" string="Falta"
                        domain="[('nature', '=', 'falta')]"/>
                <filter name="f_tempo" string="Tempo"
                        domain="[('nature', '=', 'tempo')]"/>
                <separator/>
                <filter name="f_date" string="Date" date="date"/>
                <group>
                    <filter name="g_nature" string="Nature" domain="[]"
                            context="{'group_by': 'nature'}"/>
                    <filter name="g_partner" string="Customer" domain="[]"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="g_product" string="Title" domain="[]"
                            context="{'group_by': 'product_id'}"/>
                    <filter name="g_campaign" string="Campaign" domain="[]"
                            context="{'group_by': 'campaign_id'}"/>
                    <filter name="g_team" string="Sales Channel" domain="[]"
                            context="{'group_by': 'team_id'}"/>
                    <filter name="g_month" string="Date" domain="[]"
                            context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_shortfall" model="ir.actions.act_window">
        <field name="name">Ruptura</field>
        <field name="res_model">consignment.shortfall</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="search_view_id" ref="view_shortfall_search"/>
        <field name="domain">[]</field>
        <field name="context">{'search_default_g_nature': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Nothing short.</p>
            <p>Every campaign target that was not met, with its cause. Group by
               Nature to see whether you are losing copies to the warehouse, to
               a person, to a skipped campaign, or to one nobody has run.</p>
        </field>
    </record>

    <menuitem id="menu_shortfall"
              name="Ruptura"
              parent="liber_soc_moves.menu_consignment_stock_root"
              action="action_shortfall"
              sequence="40"/>

</odoo>
