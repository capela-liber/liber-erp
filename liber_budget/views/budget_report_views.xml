<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="budget_report_view_pivot" model="ir.ui.view">
        <field name="name">budget.report.pivot</field>
        <field name="model">budget.report</field>
        <field name="arch" type="xml">
            <pivot string="Budget Analysis">
                <field name="group_id" type="row"/>
                <field name="position_id" type="row"/>
                <field name="planned" type="measure"/>
                <field name="practical" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="budget_report_view_graph" model="ir.ui.view">
        <field name="name">budget.report.graph</field>
        <field name="model">budget.report</field>
        <field name="arch" type="xml">
            <graph string="Budget Analysis" type="bar">
                <field name="position_id"/>
                <field name="planned" type="measure"/>
                <field name="practical" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="budget_report_view_list" model="ir.ui.view">
        <field name="name">budget.report.list</field>
        <field name="model">budget.report</field>
        <field name="arch" type="xml">
            <list string="Budget Analysis">
                <field name="budget_analytic_id"/>
                <field name="group_id" optional="show"/>
                <field name="position_id" optional="show"/>
                <field name="account_id" optional="hide"/>
                <field name="planned" sum="Planned"/>
                <field name="theoretical" sum="Theoretical"/>
                <field name="programmed" sum="Programmed"/>
                <field name="practical" sum="Practical"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="budget_report_view_search" model="ir.ui.view">
        <field name="name">budget.report.search</field>
        <field name="model">budget.report</field>
        <field name="arch" type="xml">
            <search>
                <field name="budget_analytic_id"/>
                <field name="group_id"/>
                <field name="position_id"/>
                <field name="account_id"/>
                <filter name="group_budget" string="Budget" context="{'group_by': 'budget_analytic_id'}"/>
                <filter name="group_group" string="Group" context="{'group_by': 'group_id'}"/>
                <filter name="group_position" string="Budgetary Position" context="{'group_by': 'position_id'}"/>
            </search>
        </field>
    </record>

    <record id="budget_report_action" model="ir.actions.act_window">
        <field name="name">Budget Analysis</field>
        <field name="res_model">budget.report</field>
        <field name="view_mode">pivot,graph,list</field>
    </record>

    <menuitem id="menu_budget_reporting" parent="menu_budget_root"
              name="Reporting" sequence="50"/>
    <menuitem id="menu_budget_report" parent="menu_budget_reporting"
              action="budget_report_action" sequence="10"/>

</odoo>
