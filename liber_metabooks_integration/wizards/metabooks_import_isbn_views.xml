<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="metabooks_import_isbn_form" model="ir.ui.view">
        <field name="name">metabooks.import.isbn.form</field>
        <field name="model">metabooks.import.isbn</field>
        <field name="arch" type="xml">
            <form string="Import from Metabooks (ISBN)">
                <group>
                    <field name="isbns" placeholder="9786551590153&#10;978-85-7715-049-6"
                           widget="text"/>
                </group>
                <footer>
                    <button name="action_import" type="object" string="Import"
                            class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_metabooks_import_isbn" model="ir.actions.act_window">
        <field name="name">Import from Metabooks (ISBN)</field>
        <field name="res_model">metabooks.import.isbn</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_metabooks_import_isbn"
              name="Import by ISBN"
              parent="liber_metabooks_integration.menu_metabooks_imports"
              action="action_metabooks_import_isbn"
              sequence="3"/>
</odoo>
