<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="import_metadata_wizard_view_form" model="ir.ui.view">
            <field name="name">import.metadata.wizard.form</field>
            <field name="model">import.metadata.wizard</field>
            <field name="arch" type="xml">
                <form>
                    <group>
                        <group>
                            <field name="vendor_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="metadata_file" required="1"/>
                        </group>
                    </group>

                    <footer>
                        <button class="oe_highlight" name="action_import_metadata" string="Import" type="object"/>
                        Or
                        <button string="Discard" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</odoo>