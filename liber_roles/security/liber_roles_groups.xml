<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_liber_roles" model="ir.module.category">
        <field name="name">Liber / Funções</field>
        <field name="description">Perfis por função da casa: um nível por departamento, mais a Direção. Os grupos do Odoo derivam daqui.</field>
        <field name="sequence">1</field>
    </record>

    <!-- v19: res.groups no longer carries category_id directly; it is held by a
         res.groups.privilege that the groups link to via privilege_id. One
         privilege per DEPARTMENT: the user form then offers the levels of each
         department as a single selection, and Direção (its own privilege)
         can be accumulated by a director who also runs a department. -->
    <record id="privilege_direcao" model="res.groups.privilege">
        <field name="name">Direção</field>
        <field name="sequence">1</field>
        <field name="category_id" ref="module_category_liber_roles"/>
    </record>
    <record id="privilege_comercial" model="res.groups.privilege">
        <field name="name">Comercial</field>
        <field name="sequence">2</field>
        <field name="category_id" ref="module_category_liber_roles"/>
    </record>
    <record id="privilege_financeiro" model="res.groups.privilege">
        <field name="name">Financeiro</field>
        <field name="sequence">3</field>
        <field name="category_id" ref="module_category_liber_roles"/>
    </record>
    <record id="privilege_editorial" model="res.groups.privilege">
        <field name="name">Editorial</field>
        <field name="sequence">4</field>
        <field name="category_id" ref="module_category_liber_roles"/>
    </record>
    <record id="privilege_marketing" model="res.groups.privilege">
        <field name="name">Marketing</field>
        <field name="sequence">5</field>
        <field name="category_id" ref="module_category_liber_roles"/>
    </record>
    <record id="privilege_visitante" model="res.groups.privilege">
        <field name="name">Visitante</field>
        <field name="sequence">6</field>
        <field name="category_id" ref="module_category_liber_roles"/>
    </record>

    <!-- ============================================================== -->
    <!-- Direção: leitura ampla + boards financeiros. Não operacional   -->
    <!-- (na v1 a edição ainda não é bloqueada; fase 2). Diretor que    -->
    <!-- opera uma área acumula também o nível daquela área.            -->
    <!-- ============================================================== -->
    <record id="group_direcao" model="res.groups">
        <field name="name">Diretor(a)</field>
        <field name="privilege_id" ref="privilege_direcao"/>
        <field name="implied_ids" eval="[
            (4, ref('base.group_user')),
            (4, ref('account.group_account_readonly')),
            (4, ref('liber_budget.group_budget_user')),
            (4, ref('sales_team.group_sale_salesman_all_leads')),
            (4, ref('liber_soc_agreements.group_soc_user')),
            (4, ref('liber_copyright_contracts.group_contract_user')),
            (4, ref('stock.group_stock_user')),
            (4, ref('project.group_project_user')),
        ]"/>
        <field name="comment">Sócios e diretores: relatórios contábeis (leitura), boards do orçamento, visão de vendas, consignação, contratos, estoque e projetos.</field>
    </record>

    <!-- ============================================================== -->
    <!-- Comercial                                                      -->
    <!-- ============================================================== -->
    <record id="group_comercial_assistente" model="res.groups">
        <field name="name">Assistente</field>
        <field name="privilege_id" ref="privilege_comercial"/>
        <field name="implied_ids" eval="[
            (4, ref('sales_team.group_sale_salesman_all_leads')),
            (4, ref('liber_soc_agreements.group_soc_user')),
            (4, ref('stock.group_stock_user')),
            (4, ref('base.group_partner_manager')),
        ]"/>
        <field name="comment">Opera o dia a dia comercial: pedidos, acertos de consignação, devoluções, clientes. Vê todos os documentos de venda (v1). Sem relatórios financeiros.</field>
    </record>

    <record id="group_comercial_gerente" model="res.groups">
        <field name="name">Gerente</field>
        <field name="privilege_id" ref="privilege_comercial"/>
        <field name="implied_ids" eval="[
            (4, ref('group_comercial_assistente')),
            (4, ref('sales_team.group_sale_manager')),
            (4, ref('liber_soc_agreements.group_soc_manager')),
        ]"/>
        <field name="comment">Tudo do assistente + administra vendas e consignação: fecha contratos AC, cria campanhas, ajusta réguas de cobrança de devolução, relatórios do canal.</field>
    </record>

    <!-- ============================================================== -->
    <!-- Financeiro. A regra de ouro dos boards mora aqui: o painel do  -->
    <!-- orçamento exige os grupos do `budget` e os relatórios          -->
    <!-- contábeis exigem account_readonly+, e só Gerente (e Direção)   -->
    <!-- os recebem. O Assistente é Cobrança: fatura e paga, não lê     -->
    <!-- consolidado.                                                   -->
    <!-- ============================================================== -->
    <record id="group_financeiro_assistente" model="res.groups">
        <field name="name">Assistente</field>
        <field name="privilege_id" ref="privilege_financeiro"/>
        <field name="implied_ids" eval="[
            (4, ref('account.group_account_invoice')),
            (4, ref('base.group_partner_manager')),
        ]"/>
        <field name="comment">Cobrança: cria faturas, registra e prepara pagamentos, concilia. Sem relatórios contábeis, sem orçamento, sem boards.</field>
    </record>

    <record id="group_financeiro_gerente" model="res.groups">
        <field name="name">Gerente</field>
        <field name="privilege_id" ref="privilege_financeiro"/>
        <field name="implied_ids" eval="[
            (4, ref('group_financeiro_assistente')),
            (4, ref('account.group_account_manager')),
            (4, ref('liber_budget.group_budget_manager')),
        ]"/>
        <field name="comment">Contabilidade completa: valida e estorna, configura plano de contas e impostos, administra o orçamento, vê os boards financeiros. Pagamentos de royalties.</field>
    </record>

    <!-- ============================================================== -->
    <!-- Editorial. Autores são parceiros (partner_manager); o catálogo -->
    <!-- (produtos/Metabooks) chega via stock_user.                     -->
    <!-- ============================================================== -->
    <record id="group_editorial_assistente" model="res.groups">
        <field name="name">Assistente</field>
        <field name="privilege_id" ref="privilege_editorial"/>
        <field name="implied_ids" eval="[
            (4, ref('liber_copyright_contracts.group_contract_user')),
            (4, ref('stock.group_stock_user')),
            (4, ref('base.group_partner_manager')),
        ]"/>
        <field name="comment">Opera contratos de direitos autorais e edita fichas do catálogo. Consulta os cálculos de royalty; não fecha períodos.</field>
    </record>

    <record id="group_editorial_gerente" model="res.groups">
        <field name="name">Gerente</field>
        <field name="privilege_id" ref="privilege_editorial"/>
        <field name="implied_ids" eval="[
            (4, ref('group_editorial_assistente')),
            (4, ref('liber_copyright_contracts.group_contract_manager')),
        ]"/>
        <field name="comment">Editor: administra contratos de direitos, fecha períodos de royalty, arquiva títulos. Vê valores a pagar dos contratos (pagar é do Financeiro).</field>
    </record>

    <!-- ============================================================== -->
    <!-- Marketing: conteúdo do site. Vê campanhas de consignação (via  -->
    <!-- soc_user no Gerente); criá-las é do Comercial. mass_mailing    -->
    <!-- não está instalado; quando entrar, os grupos entram aqui.      -->
    <!-- ============================================================== -->
    <record id="group_marketing_assistente" model="res.groups">
        <field name="name">Assistente</field>
        <field name="privilege_id" ref="privilege_marketing"/>
        <field name="implied_ids" eval="[
            (4, ref('website.group_website_restricted_editor')),
        ]"/>
        <field name="comment">Edita conteúdo do site. Sem dados financeiros.</field>
    </record>

    <record id="group_marketing_gerente" model="res.groups">
        <field name="name">Gerente</field>
        <field name="privilege_id" ref="privilege_marketing"/>
        <field name="implied_ids" eval="[
            (4, ref('group_marketing_assistente')),
            (4, ref('website.group_website_designer')),
            (4, ref('liber_soc_agreements.group_soc_user')),
        ]"/>
        <field name="comment">Publica e configura o site; acompanha campanhas de consignação (criar é do Comercial). Sem dados financeiros.</field>
    </record>

    <!-- ============================================================== -->
    <!-- Visitante: a conta da apresentação pública. Vê o produto        -->
    <!-- inteiro, não grava nada.                                       -->
    <!--                                                                -->
    <!-- Aqui os grupos são generosos DE PROPÓSITO: como models/         -->
    <!-- ir_model_access.py corta todo create/write/unlink deste grupo,  -->
    <!-- o nível "gerente" não dá poder nenhum a mais: dá VISIBILIDADE.  -->
    <!-- É a diferença entre demonstrar o sistema e demonstrar um        -->
    <!-- sistema com metade dos menus faltando.                          -->
    <!--                                                                -->
    <!-- Duas ausências deliberadas:                                    -->
    <!-- - account_manager: leitura basta para os relatórios contábeis; -->
    <!--   o nível gerente só acrescentaria telas de configuração.      -->
    <!-- - base.group_allow_export: a conta é pública e circula. Sem     -->
    <!--   escrita ela ainda poderia levar a base embora em .xlsx.       -->
    <!-- ============================================================== -->
    <record id="group_visitante" model="res.groups">
        <field name="name">Visitante (demonstração)</field>
        <field name="privilege_id" ref="privilege_visitante"/>
        <field name="implied_ids" eval="[
            (4, ref('base.group_user')),
            (4, ref('account.group_account_readonly')),
            (4, ref('liber_budget.group_budget_manager')),
            (4, ref('sales_team.group_sale_manager')),
            (4, ref('liber_soc_agreements.group_soc_manager')),
            (4, ref('liber_copyright_contracts.group_contract_manager')),
            (4, ref('stock.group_stock_manager')),
            (4, ref('project.group_project_user')),
            (4, ref('website.group_website_restricted_editor')),
        ]"/>
        <field name="comment">Conta de demonstração pública: navega por todo o sistema, abre relatórios e escreve no chatter, mas não cria, altera nem apaga documento nenhum. A trava é no ORM, não no menu.</field>
    </record>

</odoo>
