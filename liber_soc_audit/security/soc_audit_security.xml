<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Multi-company: a user only sees audits of the companies selected in the
         company switcher (records with no company stay visible to all). -->
    <record id="consignment_audit_company_rule" model="ir.rule">
        <field name="name">Consignment Audit: multi-company</field>
        <field name="model_id" ref="model_consignment_audit"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_id', 'in', company_ids), ('company_id', '=', False)]</field>
    </record>
</odoo>
