<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_soc_audit" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.soc.audit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="liber_soc_settlement.res_config_settings_view_form_soc"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='liber_soc_agreements']" position="inside">
                <block title="Consignment Audit" name="soc_audit_accounts">
                    <setting id="soc_adjustment_account_setting"
                             string="Adjustment account"
                             help="P&amp;L account that receives the value difference when an audit adjustment corrects the shelf (shrinkage or found stock).">
                        <field name="consignment_adjustment_account_id"/>
                    </setting>
                    <setting id="soc_adjustment_location_setting"
                             string="Adjustment location"
                             help="Inventory location the audit adjustments move stock to/from. Created automatically on first use; its valuation accounts are kept in sync with the account above.">
                        <field name="consignment_adjustment_location_id" readonly="1"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>

</odoo>
