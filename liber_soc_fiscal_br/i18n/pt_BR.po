#: code:addons/liber_soc_fiscal_br/models/sale_order.py:0
msgid ""
"%(order)s carries CFOP %(cfop)s (%(kind)s) and cannot be a Pedido C.\n"
"\n"
"A bonus is given away -- it leaves the stock and never becomes revenue. An event shipment comes back to us. Neither belongs on a customer's consignment shelf, and neither is ever settled."
msgstr ""

#. module: liber_soc_fiscal_br
#. odoo-python
#: code:addons/liber_soc_fiscal_br/models/sale_order.py:0
msgid ""
"%(order)s carries CFOP %(cfop)s, a consignment shipment: the books stay "
"ours, on the customer's shelf. It has to be a Pedido C."
msgstr ""

#. module: liber_soc_fiscal_br
#. odoo-python
#: code:addons/liber_soc_fiscal_br/models/sale_order.py:0
