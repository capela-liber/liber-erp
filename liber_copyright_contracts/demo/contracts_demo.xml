<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Contratos de exemplo usando favorecidos e obras padrão
         da demo do Odoo (res.partner / product.template).
         O número (name) é gerado automaticamente pela sequência.
         ============================================================ -->

    <!-- C1 — Válido, auto-renovável, dois favorecidos na mesma obra -->
    <record id="contract_demo_1" model="edlab.contract">
        <field name="signature_date">2018-03-12</field>
        <field name="expiration_date">2028-03-12</field>
        <field name="auto_renew">True</field>
        <field name="location">https://drive.example.com/contratos/2018/customizable-desk.pdf</field>
        <field name="state">valid</field>
    </record>
    <record id="contract_demo_1_line_1" model="edlab.contract.royalty.line">
        <field name="contract_id" ref="contract_demo_1"/>
        <field name="partner_id" ref="base.res_partner_address_1"/>
        <field name="product_id" ref="product.product_product_4_product_template"/>
        <field name="recoupable_advance">5000.0</field>
        <field name="non_recoupable_advance">1000.0</field>
    </record>
    <record id="contract_demo_1_l1_t1" model="edlab.contract.royalty.tier">
        <field name="line_id" ref="contract_demo_1_line_1"/>
        <field name="qty_from">0</field>
        <field name="qty_to">3000</field>
        <field name="percentage">10.0</field>
    </record>
    <record id="contract_demo_1_l1_t2" model="edlab.contract.royalty.tier">
        <field name="line_id" ref="contract_demo_1_line_1"/>
        <field name="qty_from">3001</field>
        <field name="qty_to">0</field>
        <field name="percentage">12.0</field>
    </record>
    <record id="contract_demo_1_line_2" model="edlab.contract.royalty.line">
        <field name="contract_id" ref="contract_demo_1"/>
        <field name="partner_id" ref="base.res_partner_address_2"/>
        <field name="product_id" ref="product.product_product_4_product_template"/>
    </record>
    <record id="contract_demo_1_l2_t1" model="edlab.contract.royalty.tier">
        <field name="line_id" ref="contract_demo_1_line_2"/>
        <field name="qty_from">0</field>
        <field name="qty_to">0</field>
        <field name="percentage">5.0</field>
    </record>

    <!-- C2 — Renovado, auto-renovável, faixas progressivas -->
    <record id="contract_demo_2" model="edlab.contract">
        <field name="signature_date">2019-06-01</field>
        <field name="expiration_date">2029-06-01</field>
        <field name="auto_renew">True</field>
        <field name="location">https://drive.example.com/contratos/2019/conference-chair.pdf</field>
        <field name="state">renewed</field>
    </record>
    <record id="contract_demo_2_line_1" model="edlab.contract.royalty.line">
        <field name="contract_id" ref="contract_demo_2"/>
        <field name="partner_id" ref="base.res_partner_address_3"/>
        <field name="product_id" ref="product.product_product_11_product_template"/>
        <field name="recoupable_advance">8000.0</field>
    </record>
    <record id="contract_demo_2_l1_t1" model="edlab.contract.royalty.tier">
        <field name="line_id" ref="contract_demo_2_line_1"/>
        <field name="qty_from">0</field>
        <field name="qty_to">5000</field>
        <field name="percentage">8.0</field>
    </record>
    <record id="contract_demo_2_l1_t2" model="edlab.contract.royalty.tier">
        <field name="line_id" ref="contract_demo_2_line_1"/>
        <field name="qty_from">5001</field>
        <field name="qty_to">10000</field>
        <field name="percentage">10.0</field>
    </record>
    <record id="contract_demo_2_l1_t3" model="edlab.contract.royalty.tier">
        <field name="line_id" ref="contract_demo_2_line_1"/>
        <field name="qty_from">10001</field>
        <field name="qty_to">0</field>
        <field name="percentage">12.0</field>
    </record>

    <!-- C3 — Vencido, dois favorecidos em obras diferentes -->
    <record id="contract_demo_3" model="edlab.contract">
        <field name="signature_date">2020-01-15</field>
        <field name="expiration_date">2022-01-15</field>
        <field name="state">expired</field>
    </record>
    <record id="contract_demo_3_line_1" model="edlab.contract.royalty.line">
        <field name="contract_id" ref="contract_demo_3"/>
        <field name="partner_id" ref="base.res_partner_address_4"/>
        <field name="product_id" ref="product.product_product_4_product_template"/>
        <field name="recoupable_advance">2000.0</field>
        <field name="non_recoupable_advance">500.0</field>
    </record>
    <record id="contract_demo_3_l1_t1" model="edlab.contract.royalty.tier">
        <field name="line_id" ref="contract_demo_3_line_1"/>
        <field name="qty_from">0</field>
        <field name="qty_to">0</field>
        <field name="percentage">7.0</field>
    </record>
    <record id="contract_demo_3_line_2" model="edlab.contract.royalty.line">
        <field name="contract_id" ref="contract_demo_3"/>
        <field name="partner_id" ref="base.res_partner_address_5"/>
        <field name="product_id" ref="product.product_product_11_product_template"/>
    </record>
    <record id="contract_demo_3_l2_t1" model="edlab.contract.royalty.tier">
        <field name="line_id" ref="contract_demo_3_line_2"/>
        <field name="qty_from">0</field>
        <field name="qty_to">0</field>
        <field name="percentage">7.0</field>
    </record>

    <!-- C4 — Cancelado -->
    <record id="contract_demo_4" model="edlab.contract">
        <field name="signature_date">2021-09-09</field>
        <field name="expiration_date">2026-09-09</field>
        <field name="state">cancelled</field>
    </record>
    <record id="contract_demo_4_line_1" model="edlab.contract.royalty.line">
        <field name="contract_id" ref="contract_demo_4"/>
        <field name="partner_id" ref="base.res_partner_address_7"/>
        <field name="product_id" ref="product.product_product_11_product_template"/>
        <field name="recoupable_advance">3000.0</field>
    </record>
    <record id="contract_demo_4_l1_t1" model="edlab.contract.royalty.tier">
        <field name="line_id" ref="contract_demo_4_line_1"/>
        <field name="qty_from">0</field>
        <field name="qty_to">2000</field>
        <field name="percentage">9.0</field>
    </record>
    <record id="contract_demo_4_l1_t2" model="edlab.contract.royalty.tier">
        <field name="line_id" ref="contract_demo_4_line_1"/>
        <field name="qty_from">2001</field>
        <field name="qty_to">0</field>
        <field name="percentage">11.0</field>
    </record>

</odoo>
