<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_edlab_contract_reassign_form" model="ir.ui.view">
        <field name="name">edlab.contract.reassign.form</field>
        <field name="model">edlab.contract.reassign</field>
        <field name="arch" type="xml">
            <form string="Reassign Responsible">
                <group>
                    <field name="user_id"/>
                </group>
                <field name="contract_ids" invisible="1"/>
                <footer>
                    <button name="action_apply" type="object" string="Reassign"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_edlab_contract_reassign" model="ir.actions.act_window">
        <field name="name">Reassign Responsible</field>
        <field name="res_model">edlab.contract.reassign</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_edlab_contract"/>
        <field name="binding_view_types">list,form</field>
    </record>

</odoo>
