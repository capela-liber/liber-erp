<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_edlab_contract_form" model="ir.ui.view">
        <field name="name">edlab.contract.form</field>
        <field name="model">edlab.contract</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_validate" type="object" string="Validate"
                            class="btn-primary"
                            invisible="state == 'valid'"/>
                    <button name="action_renew" type="object" string="Renew"
                            invisible="state in ('draft', 'cancelled')"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state == 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,valid,expired,renewed,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Contract"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <field name="tag_ids" widget="many2many_tags"
                           options="{'color_field': 'color'}"
                           placeholder="Tags..."/>
                    <group>
                        <group string="Dates">
                            <field name="signature_date"/>
                            <field name="expiration_date"/>
                            <field name="renewal_period_years"/>
                            <field name="time_left_display"/>
                            <field name="auto_renew"/>
                        </group>
                        <group string="Values and file">
                            <field name="user_id"/>
                            <field name="location" widget="url"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Royalties" name="royalties">
                            <field name="royalty_line_ids">
                                <list>
                                    <field name="partner_id"/>
                                    <field name="product_id"/>
                                    <field name="recoupable_advance" optional="show"/>
                                    <field name="non_recoupable_advance" optional="hide"/>
                                    <field name="currency_id" invisible="1"/>
                                </list>
                                <form>
                                    <group>
                                        <field name="partner_id"/>
                                        <field name="product_id"/>
                                        <field name="recoupable_advance"/>
                                        <field name="non_recoupable_advance"/>
                                        <field name="currency_id" invisible="1"/>
                                    </group>
                                    <separator string="Copies tiers"/>
                                    <field name="tier_ids">
                                        <list editable="bottom">
                                            <field name="qty_from"/>
                                            <field name="qty_to"/>
                                            <field name="percentage"/>
                                        </list>
                                    </field>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_edlab_contract_tree" model="ir.ui.view">
        <field name="name">edlab.contract.tree</field>
        <field name="model">edlab.contract</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="signature_date"/>
                <field name="expiration_date"/>
                <field name="time_left_display" string="Time Left"/>
                <field name="activity_ids" widget="list_activity" optional="show"/>
                <field name="user_id" optional="show"/>
                <field name="tag_ids" widget="many2many_tags"
                       options="{'color_field': 'color'}" optional="show"/>
                <field name="partner_ids" widget="many2many_tags" string="Beneficiaries"/>
                <field name="product_ids" widget="many2many_tags" string="Works"/>
                <field name="auto_renew" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'valid'"
                       decoration-warning="state == 'renewed'"
                       decoration-danger="state == 'expired'"
                       decoration-muted="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="view_edlab_contract_kanban" model="ir.ui.view">
        <field name="name">edlab.contract.kanban</field>
        <field name="model">edlab.contract</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="state"/>
                <field name="signature_date"/>
                <field name="expiration_date"/>
                <field name="time_left_display"/>
                <field name="auto_renew"/>
                <field name="user_id"/>
                <field name="partner_ids"/>
                <field name="product_ids"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="o_kanban_record_top mb8">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <span t-if="record.auto_renew.raw_value"
                                      class="badge badge-pill badge-info"
                                      title="Auto-Renewable">⟳</span>
                            </div>
                            <div class="o_kanban_record_body">
                                <div t-if="record.expiration_date.value">
                                    <i class="fa fa-calendar" role="img" aria-label="Expiration Date" title="Expiration Date"/>
                                    <span> <field name="expiration_date"/></span>
                                    <span t-if="record.time_left_display.value" class="text-muted">
                                        (<field name="time_left_display"/>)
                                    </span>
                                </div>
                                <field name="partner_ids" widget="many2many_tags"/>
                                <field name="product_ids" widget="many2many_tags"/>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left"/>
                                <div class="oe_kanban_bottom_right">
                                    <field name="user_id" widget="many2one_avatar_user"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_edlab_contract_calendar" model="ir.ui.view">
        <field name="name">edlab.contract.calendar</field>
        <field name="model">edlab.contract</field>
        <field name="arch" type="xml">
            <calendar string="Contracts" date_start="expiration_date"
                      color="state" mode="month" event_open_popup="true">
                <field name="name"/>
                <field name="state" filters="1"/>
                <field name="partner_ids"/>
            </calendar>
        </field>
    </record>

    <record id="view_edlab_contract_search" model="ir.ui.view">
        <field name="name">edlab.contract.search</field>
        <field name="model">edlab.contract</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Number"/>
                <field name="partner_ids" string="Beneficiary"/>
                <field name="product_ids" string="Work"/>
                <field name="user_id" string="Responsible"/>
                <field name="tag_ids" string="Tags"/>
                <separator/>
                <filter name="my_contracts" string="My Contracts" domain="[('user_id', '=', uid)]"/>
                <separator/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="valid" string="Valid" domain="[('state', '=', 'valid')]"/>
                <filter name="expired" string="Expired" domain="[('state', '=', 'expired')]"/>
                <filter name="renewed" string="Renewed" domain="[('state', '=', 'renewed')]"/>
                <filter name="cancelled" string="Cancelled" domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter name="auto_renew" string="Auto-Renewable" domain="[('auto_renew', '=', True)]"/>
                <filter name="expiring_soon" string="Expiring (3 months)"
                        domain="[('state', 'in', ('valid', 'renewed')), ('expiration_date', '&gt;=', context_today().strftime('%Y-%m-%d')), ('expiration_date', '&lt;=', (context_today() + relativedelta(months=3)).strftime('%Y-%m-%d'))]"/>
                <group>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_user" string="Responsible" context="{'group_by': 'user_id'}"/>
                    <filter name="group_tags" string="Tags" context="{'group_by': 'tag_ids'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_edlab_contract" model="ir.actions.act_window">
        <field name="name">Contracts</field>
        <field name="res_model">edlab.contract</field>
        <field name="view_mode">list,kanban,calendar,form</field>
        <field name="search_view_id" ref="view_edlab_contract_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first copyright contract
            </p>
            <p>
                Link beneficiaries to works and record royalties by copies tier.
            </p>
        </field>
    </record>

    <!-- Minimal tag form so inline "Create and edit" shows just the name
         (color is picked on the tag chip, the standard Odoo way). -->
    <record id="view_edlab_contract_tag_form" model="ir.ui.view">
        <field name="name">edlab.contract.tag.form</field>
        <field name="model">edlab.contract.tag</field>
        <field name="arch" type="xml">
            <form string="Contract Tag">
                <group>
                    <field name="name"/>
                </group>
            </form>
        </field>
    </record>

</odoo>
