<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_copyright_contracts" model="ir.module.category">
        <field name="name">Copyright</field>
        <field name="sequence">20</field>
    </record>

    <!-- v19: res.groups no longer carries category_id directly; it is held by a
         res.groups.privilege that the groups link to via privilege_id. -->
    <record id="privilege_copyright_contracts" model="res.groups.privilege">
        <field name="name">Copyright Contracts</field>
        <field name="category_id" ref="module_category_copyright_contracts"/>
    </record>

    <record id="group_contract_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="privilege_copyright_contracts"/>
    </record>

    <record id="group_contract_manager" model="res.groups">
        <field name="name">Administrator</field>
        <field name="privilege_id" ref="privilege_copyright_contracts"/>
        <field name="implied_ids" eval="[(4, ref('group_contract_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>
</odoo>
