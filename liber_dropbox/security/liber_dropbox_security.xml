<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_liber_dropbox" model="ir.module.category">
        <field name="name">Dropbox Files</field>
        <field name="sequence">23</field>
    </record>

    <record id="privilege_liber_dropbox" model="res.groups.privilege">
        <field name="name">Dropbox Files</field>
        <field name="category_id" ref="module_category_liber_dropbox"/>
    </record>

    <!-- Membership here only opens the Dropbox app; model permissions come
         from the implied Cloud Files base groups, and WHICH folders a user
         reaches is decided folder by folder, on the folder's own ACL. -->
    <record id="group_liber_dropbox_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="privilege_liber_dropbox"/>
        <field name="implied_ids"
               eval="[(4, ref('liber_cloud_files.group_liber_cloud_user'))]"/>
    </record>

    <record id="group_liber_dropbox_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_liber_dropbox"/>
        <field name="implied_ids"
               eval="[(4, ref('group_liber_dropbox_user')),
                      (4, ref('liber_cloud_files.group_liber_cloud_manager'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <!-- The Dropbox manager sees every DROPBOX folder and file — and only
         those: the other providers' shelves are none of their business. -->
    <record id="rule_liber_dropbox_folder_manager" model="ir.rule">
        <field name="name">Dropbox managers see every Dropbox folder</field>
        <field name="model_id"
               ref="liber_cloud_files.model_liber_cloud_folder"/>
        <field name="domain_force">[('provider', '=', 'dropbox')]</field>
        <field name="groups" eval="[(4, ref('group_liber_dropbox_manager'))]"/>
    </record>

    <record id="rule_liber_dropbox_file_manager" model="ir.rule">
        <field name="name">Dropbox managers see every Dropbox file</field>
        <field name="model_id"
               ref="liber_cloud_files.model_liber_cloud_file"/>
        <field name="domain_force">[('provider', '=', 'dropbox')]</field>
        <field name="groups" eval="[(4, ref('group_liber_dropbox_manager'))]"/>
    </record>

</odoo>
