<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_liber_dropbox" model="ir.module.category">
        <field name="name">Dropbox Files</field>
        <field name="sequence">22</field>
    </record>

    <!-- v19: res.groups no longer carries category_id directly; it is held by a
         res.groups.privilege that the groups link to via privilege_id. -->
    <record id="privilege_liber_dropbox" model="res.groups.privilege">
        <field name="name">Dropbox Files</field>
        <field name="category_id" ref="module_category_liber_dropbox"/>
    </record>

    <!-- Membership here only opens the app. WHICH folders a user reads or
         writes is decided folder by folder, on the folder's own ACL. -->
    <record id="group_liber_dropbox_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="privilege_liber_dropbox"/>
    </record>

    <record id="group_liber_dropbox_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_liber_dropbox"/>
        <field name="implied_ids" eval="[(4, ref('group_liber_dropbox_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <!-- A folder with no read group is not public, it is managers-only:
         the safe default for a module whose point is restriction. -->
    <record id="rule_liber_dropbox_folder_user" model="ir.rule">
        <field name="name">Folders the user was granted</field>
        <field name="model_id" ref="model_liber_dropbox_folder"/>
        <field name="domain_force">['|',
            ('read_group_ids', 'in', user.all_group_ids.ids),
            ('write_group_ids', 'in', user.all_group_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('group_liber_dropbox_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_liber_dropbox_folder_manager" model="ir.rule">
        <field name="name">Managers see every folder</field>
        <field name="model_id" ref="model_liber_dropbox_folder"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_liber_dropbox_manager'))]"/>
    </record>

    <record id="rule_liber_dropbox_file_user" model="ir.rule">
        <field name="name">Files of granted folders</field>
        <field name="model_id" ref="model_liber_dropbox_file"/>
        <field name="domain_force">['|',
            ('folder_id.read_group_ids', 'in', user.all_group_ids.ids),
            ('folder_id.write_group_ids', 'in', user.all_group_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('group_liber_dropbox_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Without this rule, granting the model-level write permission would
         let a user edit ANY file record: an operation no rule covers is an
         operation no rule restricts. -->
    <record id="rule_liber_dropbox_file_user_write" model="ir.rule">
        <field name="name">Users edit files of folders they write to</field>
        <field name="model_id" ref="model_liber_dropbox_file"/>
        <field name="domain_force">[('folder_id.write_group_ids', 'in', user.all_group_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('group_liber_dropbox_user'))]"/>
        <field name="perm_read" eval="False"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_liber_dropbox_file_manager" model="ir.rule">
        <field name="name">Managers see every file</field>
        <field name="model_id" ref="model_liber_dropbox_file"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_liber_dropbox_manager'))]"/>
    </record>

</odoo>
