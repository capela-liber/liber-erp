<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="cron_liber_dropbox_sync" model="ir.cron">
        <field name="name">Dropbox: daily folder sync</field>
        <field name="model_id" ref="model_liber_dropbox_folder"/>
        <field name="state">code</field>
        <field name="code">model._cron_sync()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <!-- 06:00 UTC = madrugada no Brasil: a estante amanhece espelhada. -->
        <field name="nextcall"
               eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d 06:00:00')"/>
        <field name="active" eval="True"/>
    </record>

</odoo>
