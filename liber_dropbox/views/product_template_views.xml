<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_template_form_liber_dropbox" model="ir.ui.view">
        <field name="name">product.template.form.inherit.liber.dropbox</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_dropbox_files" type="object"
                        class="oe_stat_button" icon="fa-dropbox"
                        groups="liber_dropbox.group_liber_dropbox_user"
                        invisible="not dropbox_file_count">
                    <field name="dropbox_file_count" widget="statinfo"
                           string="Files"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
