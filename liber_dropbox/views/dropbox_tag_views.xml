<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_liber_dropbox_tag_list" model="ir.ui.view">
        <field name="name">liber.dropbox.tag.list</field>
        <field name="model">liber.dropbox.tag</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <record id="action_liber_dropbox_tag" model="ir.actions.act_window">
        <field name="name">Tags</field>
        <field name="res_model">liber.dropbox.tag</field>
        <field name="view_mode">list</field>
    </record>

    <menuitem id="menu_liber_dropbox_tags" name="Tags"
              parent="menu_liber_dropbox_config"
              action="action_liber_dropbox_tag" sequence="20"/>

</odoo>
