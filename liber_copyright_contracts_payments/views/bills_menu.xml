<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Royalty payment bills still to be paid -->
    <record id="action_edlab_bills_to_pay" model="ir.actions.act_window">
        <field name="name">Bills to Pay</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('edlab_contract_id', '!=', False), ('state', '!=', 'cancel'), ('payment_state', 'in', ('not_paid', 'partial'))]</field>
        <field name="context">{'default_move_type': 'in_invoice'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No royalty bills to pay</p>
            <p>Generate them from Contracts &#8250; Action &#8250; Generate Royalty Bills.</p>
        </field>
    </record>

    <!-- Paid royalty payment bills -->
    <record id="action_edlab_bills_paid" model="ir.actions.act_window">
        <field name="name">Paid Bills</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('edlab_contract_id', '!=', False), ('payment_state', 'in', ('paid', 'in_payment'))]</field>
        <field name="context">{'default_move_type': 'in_invoice', 'create': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No paid royalty bills yet</p>
        </field>
    </record>

    <!-- Bills section under Copyright (top menu, after Reports) -->
    <menuitem id="menu_edlab_bills"
              name="Bills"
              parent="liber_copyright_contracts.menu_copyright_contracts_root"
              groups="liber_copyright_contracts.group_contract_manager"
              sequence="40"/>
    <menuitem id="menu_edlab_bills_to_pay"
              name="To Pay"
              parent="menu_edlab_bills"
              action="action_edlab_bills_to_pay"
              groups="liber_copyright_contracts.group_contract_manager"
              sequence="10"/>
    <menuitem id="menu_edlab_bills_paid"
              name="Paid"
              parent="menu_edlab_bills"
              action="action_edlab_bills_paid"
              groups="liber_copyright_contracts.group_contract_manager"
              sequence="20"/>

</odoo>
