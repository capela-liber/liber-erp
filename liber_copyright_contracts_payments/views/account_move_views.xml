<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Surface the source contract + paid royalty line on the vendor bill (managers only) -->
    <record id="view_move_form_royalty_line" model="ir.ui.view">
        <field name="name">account.move.form.royalty.line</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date_due']" position="after">
                <field name="edlab_contract_id" readonly="1"
                       groups="liber_copyright_contracts.group_contract_manager"
                       invisible="not edlab_contract_id"/>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='account_id']"
                   position="after">
                <field name="edlab_royalty_line_id" optional="hide" readonly="1"
                       groups="liber_copyright_contracts.group_contract_manager"/>
            </xpath>
        </field>
    </record>

</odoo>
