<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_liber_cloud_upload_form" model="ir.ui.view">
        <field name="name">liber.cloud.upload.form</field>
        <field name="model">liber.cloud.upload</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="provider" invisible="1"/>
                    <field name="folder_id"/>
                    <field name="data" filename="file_name"/>
                    <field name="file_name"/>
                </group>
                <footer>
                    <button name="action_upload" type="object" string="Upload"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_liber_cloud_upload" model="ir.actions.act_window">
        <field name="name">Upload</field>
        <field name="res_model">liber.cloud.upload</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
