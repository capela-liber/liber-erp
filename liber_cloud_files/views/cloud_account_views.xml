<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_liber_cloud_account_list" model="ir.ui.view">
        <field name="name">liber.cloud.account.list</field>
        <field name="model">liber.cloud.account</field>
        <field name="arch" type="xml">
            <list>
                <field name="provider"/>
                <field name="company_id"/>
                <field name="share_ttl_days"/>
            </list>
        </field>
    </record>

    <record id="view_liber_cloud_account_form" model="ir.ui.view">
        <field name="name">liber.cloud.account.form</field>
        <field name="model">liber.cloud.account</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_test_connection" type="object"
                            string="Test Connection" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="provider" invisible="context.get('default_provider')"/>
                            <field name="company_id"/>
                            <field name="active"/>
                        </group>
                        <group name="sharing">
                            <field name="share_ttl_days"/>
                        </group>
                    </group>
                    <group name="credentials" string="Credentials">
                        <!-- Each provider module inserts its fields here. -->
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
