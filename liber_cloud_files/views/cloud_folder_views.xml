<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_liber_cloud_folder_list" model="ir.ui.view">
        <field name="name">liber.cloud.folder.list</field>
        <field name="model">liber.cloud.folder</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="path"/>
                <field name="company_id" optional="show"
                       groups="base.group_multi_company"/>
                <field name="recursive" optional="show"/>
                <field name="read_group_ids" widget="many2many_tags" optional="show"/>
                <field name="write_group_ids" widget="many2many_tags" optional="show"/>
                <field name="file_count" string="Files"/>
                <field name="last_sync" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_liber_cloud_folder_form" model="ir.ui.view">
        <field name="name">liber.cloud.folder.form</field>
        <field name="model">liber.cloud.folder</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_sync" type="object" string="Sync"
                            class="btn-primary"/>
                    <button name="%(action_liber_cloud_upload)d" type="action"
                            string="Upload"
                            context="{'default_folder_id': id, 'default_provider': provider}"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_files" type="object"
                                class="oe_stat_button" icon="fa-files-o">
                            <field name="file_count" widget="statinfo"
                                   string="Files"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Covers"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="provider" invisible="context.get('default_provider')"/>
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                            <field name="path" placeholder="/Editorial/Covers"/>
                            <field name="external_id"/>
                            <field name="recursive"/>
                            <field name="last_sync"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="read_group_ids" widget="many2many_tags"/>
                            <field name="write_group_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
