<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_liber_cloud_tag_list" model="ir.ui.view">
        <field name="name">liber.cloud.tag.list</field>
        <field name="model">liber.cloud.tag</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
                <field name="company_id" optional="show"
                       groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="action_liber_cloud_tag" model="ir.actions.act_window">
        <field name="name">Tags</field>
        <field name="res_model">liber.cloud.tag</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
