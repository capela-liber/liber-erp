<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_liber_cloud" model="ir.module.category">
        <field name="name">Cloud Files</field>
        <field name="sequence">22</field>
    </record>

    <!-- v19: res.groups no longer carries category_id directly; it is held by a
         res.groups.privilege that the groups link to via privilege_id. -->
    <record id="privilege_liber_cloud" model="res.groups.privilege">
        <field name="name">Cloud Files</field>
        <field name="category_id" ref="module_category_liber_cloud"/>
    </record>

    <!-- Nobody joins these two directly: each provider app (Dropbox, Drive,
         GitHub) has its own User/Manager pair that IMPLIES them. They exist
         so that model permissions and the ACL rules below are written once. -->
    <record id="group_liber_cloud_user" model="res.groups">
        <field name="name">User (any provider)</field>
        <field name="privilege_id" ref="privilege_liber_cloud"/>
    </record>

    <record id="group_liber_cloud_manager" model="res.groups">
        <field name="name">Manager (any provider)</field>
        <field name="privilege_id" ref="privilege_liber_cloud"/>
        <field name="implied_ids" eval="[(4, ref('group_liber_cloud_user'))]"/>
    </record>

    <!-- Multicompany first: nobody sees another company's mappings, tags or
         accounts, whatever their groups say. Global rules bind everyone. -->
    <record id="rule_liber_cloud_folder_company" model="ir.rule">
        <field name="name">Folders of my companies</field>
        <field name="model_id" ref="model_liber_cloud_folder"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_liber_cloud_file_company" model="ir.rule">
        <field name="name">Files of my companies</field>
        <field name="model_id" ref="model_liber_cloud_file"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_liber_cloud_account_company" model="ir.rule">
        <field name="name">Accounts of my companies</field>
        <field name="model_id" ref="model_liber_cloud_account"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_liber_cloud_tag_company" model="ir.rule">
        <field name="name">Tags of my companies</field>
        <field name="model_id" ref="model_liber_cloud_tag"/>
        <field name="domain_force">['|', ('company_id', '=', False),
                                        ('company_id', 'in', company_ids)]</field>
    </record>

    <!-- Within the company, the folder ACL decides. A folder with no read
         group is not public, it is managers-only: the safe default for a
         module whose point is restriction. -->
    <record id="rule_liber_cloud_folder_user" model="ir.rule">
        <field name="name">Folders the user was granted</field>
        <field name="model_id" ref="model_liber_cloud_folder"/>
        <field name="domain_force">['|',
            ('read_group_ids', 'in', user.all_group_ids.ids),
            ('write_group_ids', 'in', user.all_group_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('group_liber_cloud_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_liber_cloud_file_user" model="ir.rule">
        <field name="name">Files of granted folders</field>
        <field name="model_id" ref="model_liber_cloud_file"/>
        <field name="domain_force">['|',
            ('folder_id.read_group_ids', 'in', user.all_group_ids.ids),
            ('folder_id.write_group_ids', 'in', user.all_group_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('group_liber_cloud_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Without this rule, granting the model-level write permission would
         let a user edit ANY file record: an operation no rule covers is an
         operation no rule restricts. -->
    <record id="rule_liber_cloud_file_user_write" model="ir.rule">
        <field name="name">Users edit files of folders they write to</field>
        <field name="model_id" ref="model_liber_cloud_file"/>
        <field name="domain_force">[('folder_id.write_group_ids', 'in', user.all_group_ids.ids)]</field>
        <field name="groups" eval="[(4, ref('group_liber_cloud_user'))]"/>
        <field name="perm_read" eval="False"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Managers-see-everything is NOT granted here: a Dropbox manager has
         no business browsing the GitHub shelves. Each provider module adds
         the rule for its own manager group, scoped to its provider. -->

    <record id="rule_liber_cloud_folder_system" model="ir.rule">
        <field name="name">Administrators see every folder</field>
        <field name="model_id" ref="model_liber_cloud_folder"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>

    <record id="rule_liber_cloud_file_system" model="ir.rule">
        <field name="name">Administrators see every file</field>
        <field name="model_id" ref="model_liber_cloud_file"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>

</odoo>
