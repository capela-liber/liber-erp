<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- LAB FORK: kept from the original create_nfe_xml_from_edoo_mde.xml
             (same XML id); the MDE-driven cron itself was dropped with the
             edoo_br_mde dependency. -->
        <record id="cron_process_nfe_xml_content" model="ir.cron">
            <field name="name">NFe XML - Process File Content</field>
            <field name="active" eval="True" />
            <field name="user_id" ref="base.user_admin" />
            <field name="model_id" ref="model_nfe_xml_panel"/>
            <field name="interval_number">10</field>
            <field name="interval_type">minutes</field>
            <field name="state">code</field>
            <field name="code">model.cron_process_file_content()</field>
            <field name="priority" eval="5" />
        </record>
    </data>
</odoo>
