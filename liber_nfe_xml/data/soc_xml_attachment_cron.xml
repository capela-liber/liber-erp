<odoo>
    <data noupdate="0">
        <record id="nfe_xml_attach_cron" model="ir.cron">
            <field name="name">NFe XML Attachment Panel Cron </field>
            <field name="active" eval="True" />
            <field name="user_id" ref="base.user_admin" />
            <field name="model_id" ref="model_ir_attachment"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=0)).strftime('%Y-%m-%d 18:30:00')" />
            <field name="state">code</field>
            <field name="code">model.create_nfe_xml_panel_cron()</field>
            <field name="priority" eval="5" />
        </record>
