<?xml version="1.0"?>
<odoo>
    <record id="nfe_xml_tags_view_form" model="ir.ui.view">
        <field name="name">nfe.xml.tags.view.form</field>
        <field name="model">nfe.xml.tags</field>
        <field name="arch" type="xml">
            <form string="NFe Tags">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="color" required="True" widget="color_picker"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="nfe_xml_tags_view_tree" model="ir.ui.view">
        <field name="name">nfe_xml_tags_view_tree</field>
        <field name="model">nfe.xml.tags</field>
        <field name="arch" type="xml">
            <list string="NFe Tags" editable="bottom" sample="1">
                <field name="name"/>
                <field name="color" widget="color_picker" />
            </list>
        </field>
    </record>

    <record id="nfe_xml_tags_action" model="ir.actions.act_window">
        <field name="name">NFe XML Tags</field>
        <field name="res_model">nfe.xml.tags</field>
        <field name="view_id" ref="nfe_xml_tags_view_tree"/>
    </record>

    <menuitem id="nfe_xml_tags_menu" name="NFe Tags" action="nfe_xml_tags_action"
              parent="liber_nfe_xml.menu_nfe_xml_panel" sequence="3"/>
</odoo>
