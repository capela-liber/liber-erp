<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_liber_gdrive" model="ir.module.category">
        <field name="name">Google Drive Files</field>
        <field name="sequence">24</field>
    </record>

    <record id="privilege_liber_gdrive" model="res.groups.privilege">
        <field name="name">Google Drive Files</field>
        <field name="category_id" ref="module_category_liber_gdrive"/>
    </record>

    <record id="group_liber_gdrive_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="privilege_liber_gdrive"/>
        <field name="implied_ids"
               eval="[(4, ref('liber_cloud_files.group_liber_cloud_user'))]"/>
    </record>

    <record id="group_liber_gdrive_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_liber_gdrive"/>
        <field name="implied_ids"
               eval="[(4, ref('group_liber_gdrive_user')),
                      (4, ref('liber_cloud_files.group_liber_cloud_manager'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <record id="rule_liber_gdrive_folder_manager" model="ir.rule">
        <field name="name">Drive managers see every Drive folder</field>
        <field name="model_id"
               ref="liber_cloud_files.model_liber_cloud_folder"/>
        <field name="domain_force">[('provider', '=', 'gdrive')]</field>
        <field name="groups" eval="[(4, ref('group_liber_gdrive_manager'))]"/>
    </record>

    <record id="rule_liber_gdrive_file_manager" model="ir.rule">
        <field name="name">Drive managers see every Drive file</field>
        <field name="model_id"
               ref="liber_cloud_files.model_liber_cloud_file"/>
        <field name="domain_force">[('provider', '=', 'gdrive')]</field>
        <field name="groups" eval="[(4, ref('group_liber_gdrive_manager'))]"/>
    </record>

</odoo>
