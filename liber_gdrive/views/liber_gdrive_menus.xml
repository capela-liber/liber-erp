<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_liber_gdrive_file" model="ir.actions.act_window">
        <field name="name">Files</field>
        <field name="res_model">liber.cloud.file</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('provider', '=', 'gdrive')]</field>
        <field name="context">{'default_provider': 'gdrive'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No files here yet
            </p>
            <p>
                Files appear when a Drive folder you have access to is synced.
            </p>
        </field>
    </record>

    <record id="action_liber_gdrive_folder" model="ir.actions.act_window">
        <field name="name">Folders</field>
        <field name="res_model">liber.cloud.folder</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('provider', '=', 'gdrive')]</field>
        <field name="context">{'default_provider': 'gdrive'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Map a Drive folder
            </p>
            <p>
                Paste the folder's Drive ID, name who reads and who writes,
                and press Sync.
            </p>
        </field>
    </record>

    <record id="action_liber_gdrive_upload" model="ir.actions.act_window">
        <field name="name">Upload to Drive</field>
        <field name="res_model">liber.cloud.upload</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_provider': 'gdrive'}</field>
    </record>

    <record id="action_liber_gdrive_account" model="ir.actions.act_window">
        <field name="name">Account</field>
        <field name="res_model">liber.cloud.account</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('provider', '=', 'gdrive')]</field>
        <field name="context">{'default_provider': 'gdrive'}</field>
    </record>

    <menuitem id="menu_liber_gdrive_root" name="Drive"
              sequence="74"
              web_icon="liber_gdrive,static/description/icon.png"
              groups="liber_gdrive.group_liber_gdrive_user"/>

    <menuitem id="menu_liber_gdrive_files" name="Files"
              parent="menu_liber_gdrive_root"
              action="action_liber_gdrive_file" sequence="10"/>

    <menuitem id="menu_liber_gdrive_upload" name="Upload"
              parent="menu_liber_gdrive_root"
              action="action_liber_gdrive_upload" sequence="20"/>

    <menuitem id="menu_liber_gdrive_config" name="Configuration"
              parent="menu_liber_gdrive_root" sequence="90"
              groups="liber_gdrive.group_liber_gdrive_manager"/>

    <menuitem id="menu_liber_gdrive_folders" name="Folders"
              parent="menu_liber_gdrive_config"
              action="action_liber_gdrive_folder" sequence="10"/>

    <menuitem id="menu_liber_gdrive_tags" name="Tags"
              parent="menu_liber_gdrive_config"
              action="liber_cloud_files.action_liber_cloud_tag" sequence="20"/>

    <menuitem id="menu_liber_gdrive_account" name="Account"
              parent="menu_liber_gdrive_config"
              action="action_liber_gdrive_account" sequence="30"/>

</odoo>
